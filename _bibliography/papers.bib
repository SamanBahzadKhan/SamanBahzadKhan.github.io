@inproceedings{khan2025lads,
  title        = {LADs: Leveraging LLMs for AI-Driven DevOps},
  author       = {Khan, Saman Bahzad and others},
  booktitle    = {IEEE International Conference on Distributed Computing Systems (ICDCS)},
  year         = {2026},
  note         = {Under Review},
  abstract     = {LADs is an agentic LLM framework that automates the full configuration-to-deployment pipeline through a structured, self-refining feedback loop comprising configuration generation, deployment, and maintenance stages. Evaluated across 180 tasks spanning Dask, Redis, and Ray, LADs improves deployment success rates from 22% with simple prompting to 68%, corrects 94% of runtime failures within three iterations, and generates production-ready configurations at a cost four orders of magnitude lower than a conventional developer.},
  selected     = {true},
  bibtex_show  = {true},
  abbr         = {ICDCS}
}

@article{khan2025semdpo,
  title        = {Sem-DPO: Mitigating Semantic Inconsistency in Preference Optimization for Prompt Engineering},
  author       = {Mohamed, Anas and Khan, Azal Ahmad and Wang, Xinran and Khan, Ahmad Faraz and Ge, Shuwen and Khan, Saman Bahzad and Ahmad, Ayaan and Anwar, Ali},
  journal      = {ACL Rolling Review},
  year         = {2025},
  note         = {Under Review},
  abstract     = {Sem-DPO is a variant of Direct Preference Optimization (DPO) that explicitly incorporates semantic consistency into the preference alignment process. By introducing per-sample semantic consistency weights, Sem-DPO prevents optimized prompts from drifting away from the user's original intent. We provide the first analytical bound on semantic drift for preference-tuned prompt generators and demonstrate 8-12% higher CLIP similarity and 5-9% higher human preference scores over standard DPO across three benchmarks and three language model backbones.},
  selected     = {true},
  bibtex_show  = {true},
  abbr         = {ACL ARR}
}
